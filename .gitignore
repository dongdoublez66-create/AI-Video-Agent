__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
.venv/
venv/
env/
build/
dist/
*.egg-info/

# Local secrets
.env
.env.*
!.env.example

# User media and generated videos
inputs/videos/*
inputs/images/*
assets/music/*
assets/sfx/*
assets/fonts/*
assets/stickers/*
outputs/rough_cuts/*
outputs/finals/*
outputs/logs/*
outputs/custom_test/*
subtitles/*
timelines/*

# Runtime workspace
workspace/cache/*
workspace/manifests/*
workspace/runs/*
workspace/resolve_review/*

# Bundled local binaries should be installed by the user
tools/ffmpeg/bin/*

# Keep folder skeletons
!inputs/videos/.gitkeep
!inputs/images/.gitkeep
!assets/music/.gitkeep
!assets/sfx/.gitkeep
!assets/fonts/.gitkeep
!assets/stickers/.gitkeep
!outputs/rough_cuts/.gitkeep
!outputs/finals/.gitkeep
!outputs/logs/.gitkeep
!subtitles/.gitkeep
!timelines/.gitkeep
!workspace/cache/.gitkeep
!workspace/manifests/.gitkeep
!tools/ffmpeg/bin/.gitkeep
